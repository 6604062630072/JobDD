{
  "name": "jobsabuy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "bun run --filter @jobsabuy/api prisma migrate dev",
    "db:seed": "bun run --filter @jobsabuy/api prisma db seed",
    "db:studio": "bun run --filter @jobsabuy/api prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@react-pdf/renderer": "^4.5.1",
    "web": "^0.0.2"
  }
}
